# ============================================================
# matching-app 環境変数サンプル
# 実値は .env.local（git管理外）に置く。秘密情報は絶対にコミットしない。
# 詳細な取得手順: docs/setup/external-setup.md
# ============================================================

# --- 開発モード（実クレデンシャル未着でも動かすためのモックフラグ）---
# 1 でモック有効。本番は 0 もしくは未設定。
MOCK_AUTH=1
MOCK_NOTIFY=1

# --- データベース（Vercel Postgres / Neon）---
# Vercel連携時は POSTGRES_PRISMA_URL → DATABASE_URL、
# POSTGRES_URL_NON_POOLING → DIRECT_URL にマップする。
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# --- LINE Login / LIFF（docs/setup/external-setup.md §1）---
NEXT_PUBLIC_LIFF_ID=""
LINE_LOGIN_CHANNEL_ID=""
LINE_LOGIN_CHANNEL_SECRET=""

# --- LINE Messaging API（公式アカウントからの通知）---
LINE_MESSAGING_CHANNEL_ACCESS_TOKEN=""
LINE_MESSAGING_CHANNEL_SECRET=""

# --- Vercel Blob（プロフィール写真 / 身分証画像）---
BLOB_READ_WRITE_TOKEN=""

# --- Stripe（決済 / S4）---
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# --- ビジネスルール ---
PARTICIPATION_FEE_JPY=2000

# --- 管理者（初期adminのLINE userId。カンマ区切り可）---
ADMIN_LINE_USER_IDS=""

# --- 本人認証 AI 一次判定（トリガー駆動。Anthropic API は使わない）---
# Haiku は API を同期で叩かず、モーニングレポート同様「トリガーで起動したジョブ」
# (tools/ai-identity-trigger.mjs)が判定待ちキューを取得→判定→書き戻す方式。
# その専用エンドポイント(/api/admin/identity/ai-queue, .../[id]/ai-verdict)を
# 認証する共有トークン(Authorization: Bearer)。設計の正典: docs/AI_IDENTITY_TRIGGER.md
# 本番は必須(未設定だとエンドポイントは 503=フェイルクローズ)。非production は未設定可
# (開発既定 dev-ai-trigger-token)。十分長いランダム値にし、絶対にコミットしない。
AI_TRIGGER_TOKEN=""
# トリガージョブが叩く対象URL（cron 等から実行する場合。既定 http://127.0.0.1:3000）
AI_TRIGGER_BASE_URL=""

# --- CSRF 許可オリジン（SEC-003。カンマ区切り・同一オリジンは常に許可）---
# 本番では LIFF/本番ドメインを設定する（例 https://example.vercel.app）。
ALLOWED_ORIGINS=""
